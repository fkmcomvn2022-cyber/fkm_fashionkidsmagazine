# Copy this file to .env.production and fill in the REAL deployed backend
# URL before building the native Android/Mac app — without this, the
# packaged app falls back to http://localhost:4000 (see src/lib/persistence.ts
# BACKEND_URL), which does not exist once the app runs outside this dev
# machine.
#
# Firebase Hosting CHỈ host giao diện web (dist/) — KHÔNG chạy server Node.
# VITE_BACKEND_URL phải trỏ tới API thật (Render, Cloud Run, Cloud Functions…).
#
# Ví dụ:
#   Render:  https://fkm-studio-server.onrender.com
#   Cloud Run: https://fkm-api-xxxxx-as.a.run.app
VITE_BACKEND_URL=https://your-fkm-studio-server.onrender.com
