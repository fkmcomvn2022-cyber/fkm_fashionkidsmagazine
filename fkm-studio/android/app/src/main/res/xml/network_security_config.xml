<?xml version="1.0" encoding="utf-8"?>
<!-- Cho phép HTTP tới server LAN (vd. http://192.168.x.x:4000) khi chưa deploy HTTPS -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
