# Copy file này thành .env (cùng thư mục) rồi điền giá trị thật — KHÔNG commit .env (đã có trong .gitignore).
# Khi deploy lên Render/Railway, KHÔNG cần file .env — đặt thẳng các biến này ở dashboard (mục Environment).

# Cổng chạy server local (Render/Railway tự đặt PORT, không cần khai báo khi deploy)
PORT=4000

# --- Phase 2: Facebook Messenger ---
# Chuỗi TỰ ĐẶT (bất kỳ, vd "fkm_xac_minh_2026") — dùng khi khai báo webhook trên Meta for Developers,
# Meta sẽ gửi đúng chuỗi này lại để xác minh server.
FB_VERIFY_TOKEN=

# Lấy ở Meta for Developers > App của anh > Cài đặt > Cơ bản (App Secret)
FB_APP_SECRET=

# Lấy ở Meta for Developers > App > Messenger > Cài đặt Messenger > Page Access Token (theo Trang đã chọn)
FB_PAGE_ACCESS_TOKEN=

# --- Phase 3/9: AI tự động trả lời ---
# Từ Phase 9, API key + model của cả 3 nhà (Gemini/OpenAI/DeepSeek) cấu hình
# NGAY TRONG APP (Cài đặt > AI > Nhà cung cấp AI) — KHÔNG còn thuần biến môi
# trường nữa, vì cần nhập 3 key khác nhau + chọn model + đổi thứ tự ưu tiên
# retry/fallback, làm qua UI tiện hơn nhiều so với sửa biến môi trường trên
# Render mỗi lần đổi (xem server/src/aiProviders.ts).
#
# 2 biến dưới đây CHỈ còn là "mặc định ngầm" cho Gemini — nếu studio chưa
# từng nhập key Gemini qua UI, server tự dùng 2 biến này (không phá deploy cũ
# trước khi có UI). Khi đã nhập key qua UI thì UI luôn được ưu tiên hơn.
GEMINI_API_KEY=
GEMINI_MODEL=

# Lưu ý: KHÔNG có biến môi trường riêng cho OPENAI_API_KEY/DEEPSEEK_API_KEY —
# 2 nhà này chỉ cấu hình được qua UI trong app (key lưu ở
# server/data/ai-providers.json trên server, KHÔNG nằm trong state.json công
# khai — xem comment đầu aiProviders.ts để biết lý do bảo mật).
